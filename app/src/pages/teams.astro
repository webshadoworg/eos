---
import AppLayout from '~/layouts/AppLayout.astro';
import { Users, Crown, Plus, Pencil, X, Trash2, UserPlus } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const url = Astro.url;
const creating = url.searchParams.get('new') === '1';
const editId = url.searchParams.get('edit');

const allowedIds = Astro.locals.allowedTeams.map((t) => t.id);

const { data: teams } = allowedIds.length
  ? await supabase
      .from('teams')
      .select(`
        id, name, description,
        memberships:team_memberships(
          id, role, role_description, display_order,
          employee:employees(id, full_name, email)
        )
      `)
      .in('id', allowedIds)
      .order('name')
  : { data: [] };

const { data: allEmployees } = await supabase
  .from('employees')
  .select('id, full_name, email')
  .order('full_name');

const editing = editId ? (teams ?? []).find((t) => t.id === editId) ?? null : null;
const sortedMembers = editing
  ? [...(editing.memberships ?? [])]
      .filter((m: any) => m.employee)
      .sort((a: any, b: any) => (a.display_order ?? 0) - (b.display_order ?? 0))
  : [];
const memberIds = new Set(sortedMembers.map((m: any) => m.employee.id));
const availableEmployees = (allEmployees ?? []).filter((e) => !memberIds.has(e.id));

const initials = (name: string) =>
  name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();

const back = '/teams';
const editBack = editing ? `/teams?edit=${editing.id}` : back;
---
<AppLayout title="Teams · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-emerald-100 grid place-items-center">
        <Users class="text-emerald-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Teams</h1>
        <p class="text-stone-500 text-sm">All teams you're a member of</p>
      </div>
    </div>
    <a
      href="/teams?new=1"
      class="bg-stone-800 hover:bg-stone-900 text-white rounded-xl px-5 py-2.5 text-sm font-medium flex items-center gap-1.5"
    >
      <Plus size={16} />
      New Team
    </a>
  </header>

  <div class="grid gap-4">
    {teams && teams.length > 0 ? teams.map((t: any) => {
      const members = (t.memberships ?? [])
        .filter((m: any) => m.employee)
        .sort((a: any, b: any) => (a.display_order ?? 0) - (b.display_order ?? 0));
      return (
        <div class="bg-white border border-stone-200 rounded-2xl p-5">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-stone-900 text-lg">{t.name}</h3>
              {t.description && <p class="text-sm text-stone-500 mt-0.5">{t.description}</p>}
            </div>
            <div class="flex items-center gap-2">
              <div class="text-xs text-stone-400 bg-stone-50 border border-stone-200 rounded-full px-3 py-1">
                {members.length} {members.length === 1 ? 'member' : 'members'}
              </div>
              <a
                href={`/teams?edit=${t.id}`}
                class="border border-stone-300 bg-white hover:bg-stone-50 rounded-lg px-3 py-1.5 text-sm font-medium text-stone-700 flex items-center gap-1.5"
              >
                <Pencil size={14} />
                Manage
              </a>
            </div>
          </div>
          {members.length > 0 && (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
              {members.map((m: any) => (
                <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-stone-50">
                  <div class="w-9 h-9 rounded-full bg-violet-100 text-violet-700 grid place-items-center text-xs font-semibold">
                    {initials(m.employee.full_name)}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-stone-800 flex items-center gap-1 truncate">
                      {m.employee.full_name}
                      {m.role === 'admin' && <Crown size={12} class="text-amber-500 shrink-0" />}
                    </div>
                    {m.role_description && <div class="text-xs text-stone-500 truncate">{m.role_description}</div>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      );
    }) : (
      <div class="bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
        You're not a member of any teams yet.
      </div>
    )}
  </div>

  <!-- =================================================================
       CREATE TEAM slide-over
       ================================================================= -->
  {creating && (
    <div class="fixed inset-0 z-30">
      <a href={back} class="absolute inset-0 bg-black/20"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-5">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-semibold text-stone-900">New Team</h2>
            <a href={back} class="p-1 text-stone-400 hover:text-stone-700"><X size={18} /></a>
          </div>
          <form method="POST" action="/api/teams" class="space-y-4">
            <input type="hidden" name="_action" value="create" />
            <input type="hidden" name="back" value={back} />
            <div>
              <label class="text-sm font-medium text-stone-700">Name</label>
              <input type="text" name="name" required
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-400" />
            </div>
            <div>
              <label class="text-sm font-medium text-stone-700">Description</label>
              <textarea name="description" rows="3"
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-400"></textarea>
            </div>
            <p class="text-xs text-stone-500">You'll be added as an admin of this team automatically.</p>
            <button class="w-full bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg py-2.5 text-sm font-medium">
              Create team
            </button>
          </form>
        </div>
      </aside>
    </div>
  )}

  <!-- =================================================================
       MANAGE TEAM slide-over
       ================================================================= -->
  {editing && (
    <div class="fixed inset-0 z-30">
      <a href={back} class="absolute inset-0 bg-black/20"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-6">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-semibold text-stone-900">Manage Team</h2>
            <a href={back} class="p-1 text-stone-400 hover:text-stone-700"><X size={18} /></a>
          </div>

          <!-- Team details -->
          <form method="POST" action="/api/teams" class="space-y-4">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={editing.id} />
            <input type="hidden" name="back" value={editBack} />
            <div>
              <label class="text-sm font-medium text-stone-700">Name</label>
              <input type="text" name="name" required value={editing.name}
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-400" />
            </div>
            <div>
              <label class="text-sm font-medium text-stone-700">Description</label>
              <textarea name="description" rows="2"
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-400"
              >{editing.description ?? ''}</textarea>
            </div>
            <button class="w-full bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg py-2.5 text-sm font-medium">
              Save team
            </button>
          </form>

          <!-- Members -->
          <div class="pt-4 border-t border-stone-200">
            <h3 class="text-sm font-semibold text-stone-800 mb-3 flex items-center gap-2">
              <UserPlus size={16} /> Members ({sortedMembers.length})
            </h3>

            <div class="space-y-2 mb-4">
              {sortedMembers.length > 0 ? sortedMembers.map((m: any) => (
                <form method="POST" action="/api/team-memberships" class="bg-stone-50 border border-stone-200 rounded-lg p-3 space-y-2">
                  <input type="hidden" name="_action" value="update" />
                  <input type="hidden" name="id" value={m.id} />
                  <input type="hidden" name="back" value={editBack} />
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-violet-100 text-violet-700 grid place-items-center text-xs font-semibold">
                      {initials(m.employee.full_name)}
                    </div>
                    <div class="flex-1 min-w-0 text-sm font-medium text-stone-800 truncate">
                      {m.employee.full_name}
                    </div>
                    <select name="role" class="text-xs bg-white border border-stone-300 rounded px-2 py-1">
                      <option value="member" selected={m.role === 'member'}>Member</option>
                      <option value="admin" selected={m.role === 'admin'}>Admin</option>
                    </select>
                  </div>
                  <div class="flex gap-2">
                    <input
                      type="text"
                      name="role_description"
                      value={m.role_description ?? ''}
                      placeholder="Role description (optional)"
                      class="flex-1 bg-white border border-stone-300 rounded px-2 py-1 text-xs focus:outline-none focus:border-emerald-400"
                    />
                    <button class="text-xs bg-stone-800 hover:bg-stone-900 text-white rounded px-3 py-1">Save</button>
                    <button
                      type="submit"
                      formaction="/api/team-memberships"
                      onclick="this.form._action.value='delete'; if(!confirm('Remove this member from the team?')) return false;"
                      class="text-xs border border-rose-300 text-rose-700 rounded px-2 py-1"
                      title="Remove"
                    >
                      <Trash2 size={13} />
                    </button>
                  </div>
                </form>
              )) : (
                <p class="text-xs text-stone-400">No members yet.</p>
              )}
            </div>

            <!-- Add member -->
            {availableEmployees.length > 0 ? (
              <form method="POST" action="/api/team-memberships" class="bg-white border border-stone-200 rounded-lg p-3 space-y-2">
                <input type="hidden" name="_action" value="create" />
                <input type="hidden" name="team_id" value={editing.id} />
                <input type="hidden" name="back" value={editBack} />
                <div class="text-xs font-semibold text-stone-600 flex items-center gap-1">
                  <UserPlus size={13} /> Add a member
                </div>
                <div class="flex gap-2">
                  <select name="employee_id" required class="flex-1 bg-white border border-stone-300 rounded px-2 py-1.5 text-sm">
                    <option value="">Pick an employee…</option>
                    {availableEmployees.map((e) => <option value={e.id}>{e.full_name}</option>)}
                  </select>
                  <select name="role" class="bg-white border border-stone-300 rounded px-2 py-1.5 text-sm">
                    <option value="member">Member</option>
                    <option value="admin">Admin</option>
                  </select>
                  <button class="bg-emerald-600 hover:bg-emerald-700 text-white rounded px-3 py-1.5 text-sm font-medium">Add</button>
                </div>
                <input
                  type="text"
                  name="role_description"
                  placeholder="Role description (optional)"
                  class="w-full bg-white border border-stone-300 rounded px-2 py-1.5 text-xs focus:outline-none focus:border-emerald-400"
                />
              </form>
            ) : (
              <p class="text-xs text-stone-400 italic">All employees are already members of this team.</p>
            )}
          </div>

          <!-- Delete team -->
          <form
            method="POST"
            action="/api/teams"
            class="pt-4 border-t border-stone-200"
            onsubmit="return confirm('Delete this team? All memberships will be removed.');"
          >
            <input type="hidden" name="_action" value="delete" />
            <input type="hidden" name="id" value={editing.id} />
            <input type="hidden" name="back" value="/teams" />
            <button class="w-full border border-rose-300 text-rose-700 rounded-lg py-2 text-sm font-medium flex items-center justify-center gap-2">
              <Trash2 size={14} /> Delete team
            </button>
          </form>
        </div>
      </aside>
    </div>
  )}
</AppLayout>
