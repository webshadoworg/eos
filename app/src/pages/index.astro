---
import AppLayout from '~/layouts/AppLayout.astro';
import { Target, AlertCircle, ListTodo, Users, ArrowRight, Megaphone, Calendar, Plane, MapPin } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
const team = Astro.locals.currentTeam;
const teamFilter = (q: any) => (team ? q.eq('team_id', team.id) : q);

const today = new Date().toISOString().slice(0, 10);

const [
  { count: rocksCount },
  { count: openTodos },
  { count: openIssues },
  { count: employeesCount },
  { data: posts },
  { data: upcomingTrips },
] = await Promise.all([
  supabase.from('rocks').select('*', { count: 'exact', head: true }).eq('is_archived', false),
  teamFilter(supabase.from('todos').select('*', { count: 'exact', head: true }).eq('status', 'open')),
  teamFilter(supabase.from('issues').select('*', { count: 'exact', head: true }).eq('status', 'open')),
  supabase.from('employees').select('*', { count: 'exact', head: true }),
  supabase
    .from('posts')
    .select('id, kind, slug, headline, summary, category, date, image_url, screenshot_url, from_username, source, video_url')
    .order('date', { ascending: false, nullsFirst: false })
    .limit(10),
  supabase
    .from('trips')
    .select('id, city, start_date, end_date, people')
    .or(`start_date.gte.${today},end_date.gte.${today}`)
    .order('start_date', { ascending: true, nullsFirst: false })
    .limit(5),
]);

const fmtDate = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';

const stats = [
  { label: 'Active Rocks',    value: rocksCount ?? 0,    href: '/rocks',    icon: Target,      color: 'text-violet-600 bg-violet-100' },
  { label: 'Open To-Dos',     value: openTodos ?? 0,     href: '/todos',    icon: ListTodo,    color: 'text-emerald-600 bg-emerald-100' },
  { label: 'Open Issues',     value: openIssues ?? 0,    href: '/issues',   icon: AlertCircle, color: 'text-amber-600 bg-amber-100' },
  { label: 'Employees',       value: employeesCount ?? 0, href: '/teams',   icon: Users,       color: 'text-sky-600 bg-sky-100' },
];

const user = Astro.locals.user!;
const firstName = user.fullName?.split(' ')[0] || 'there';
---
<AppLayout title="Home · GYE EOS">
  <header class="mb-8">
    <h1 class="text-3xl font-semibold text-stone-900">Welcome back, {firstName}.</h1>
    <p class="text-stone-500 mt-1">
      {team ? <>Currently viewing <span class="font-medium text-stone-700">{team.name}</span>.</> : 'No team selected.'}
    </p>
  </header>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
    {stats.map((s) => (
      <a
        href={s.href}
        class="group block bg-white rounded-2xl border border-stone-200 p-5 hover:border-stone-300 hover:shadow-sm transition"
      >
        <div class={`w-10 h-10 rounded-xl grid place-items-center ${s.color}`}>
          <s.icon size={20} />
        </div>
        <div class="mt-4 text-sm text-stone-500">{s.label}</div>
        <div class="mt-1 text-3xl font-semibold text-stone-900 flex items-baseline justify-between">
          {s.value}
          <ArrowRight size={16} class="text-stone-300 group-hover:text-stone-500 transition" />
        </div>
      </a>
    ))}
  </div>

  {upcomingTrips && upcomingTrips.length > 0 && (
    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <Plane size={18} class="text-sky-600" />
          <h2 class="text-lg font-semibold text-stone-900">Upcoming Trips</h2>
        </div>
        <a href="/trips" class="text-sm font-medium text-sky-600 hover:text-sky-700">All trips →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        {upcomingTrips.map((t: any) => (
          <a
            href="/trips"
            class="bg-white border border-stone-200 rounded-2xl p-4 hover:border-sky-300 hover:shadow-sm transition block"
          >
            <div class="flex items-center gap-2 text-stone-900 font-semibold">
              <MapPin size={15} class="text-sky-600" /> {t.city}
            </div>
            {(t.start_date || t.end_date) && (
              <div class="flex items-center gap-1.5 text-sm text-stone-500 mt-1">
                <Calendar size={13} />
                {fmtDate(t.start_date)}{t.end_date && ` → ${fmtDate(t.end_date)}`}
              </div>
            )}
            {t.people && t.people.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {t.people.slice(0, 4).map((p: string) => (
                  <span class="text-xs bg-stone-50 border border-stone-200 rounded-full px-2 py-0.5 text-stone-700">{p}</span>
                ))}
                {t.people.length > 4 && (
                  <span class="text-xs text-stone-400 px-1">+{t.people.length - 4}</span>
                )}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <Megaphone size={18} class="text-violet-600" />
        <h2 class="text-lg font-semibold text-stone-900">Recent Activity</h2>
      </div>
      <a href="/posts" class="text-sm font-medium text-violet-600 hover:text-violet-700">All posts →</a>
    </div>

    {posts && posts.length > 0 ? (
      <div class="columns-1 md:columns-2 lg:columns-3 gap-5 [column-fill:_balance]">
        {posts.map((p: any) => {
          const isTestimonial = p.kind === 'testimonial';
          const thumb = p.image_url || p.screenshot_url;
          const pillColor = isTestimonial
            ? 'text-amber-700 bg-amber-50 border-amber-200'
            : 'text-violet-700 bg-violet-50 border-violet-200';
          const hoverBorder = isTestimonial ? 'hover:border-amber-300' : 'hover:border-violet-300';
          const hoverHeading = isTestimonial ? 'group-hover:text-amber-700' : 'group-hover:text-violet-700';
          return (
            <a
              href={`/posts/${p.slug}`}
              class={`group block break-inside-avoid mb-5 bg-white border border-stone-200 rounded-2xl overflow-hidden transition hover:shadow-sm ${hoverBorder}`}
            >
              {thumb && (
                <img src={thumb} alt="" loading="lazy" class="w-full bg-stone-100 group-hover:opacity-95 transition" />
              )}
              <div class="p-4">
                <div class="flex flex-wrap items-center gap-1.5 mb-1.5 text-[11px]">
                  <span class={`font-medium border rounded-full px-2 py-0.5 ${pillColor}`}>
                    {isTestimonial ? 'Testimonial' : p.category || 'Post'}
                  </span>
                  {isTestimonial && p.category && <span class="text-stone-400">· {p.category}</span>}
                  {p.date && (
                    <span class="text-stone-400 flex items-center gap-1">
                      <Calendar size={10} /> {fmtDate(p.date)}
                    </span>
                  )}
                  {p.video_url && <span class="text-rose-500 font-medium">▶ Video</span>}
                </div>
                {p.headline && (
                  <h3 class={`text-base font-semibold text-stone-900 leading-snug transition ${hoverHeading}`}>
                    {p.headline}
                  </h3>
                )}
                {p.summary && (
                  <p class={`text-[13px] text-stone-600 line-clamp-5 ${p.headline ? 'mt-1.5' : ''} ${isTestimonial ? 'italic' : ''}`}>
                    {isTestimonial ? `"${p.summary}"` : p.summary}
                  </p>
                )}
                {isTestimonial && (p.from_username || p.source) && (
                  <div class="mt-2 text-[11px] text-stone-400">
                    — {p.from_username || 'anonymous'}{p.source && <> · {p.source}</>}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
        No posts yet.
      </div>
    )}
  </section>
</AppLayout>
