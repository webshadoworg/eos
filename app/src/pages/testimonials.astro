---
import AppLayout from '~/layouts/AppLayout.astro';
import { Quote, Calendar, ExternalLink, X } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const url = Astro.url;
const category = url.searchParams.get('category') ?? 'all';
const source = url.searchParams.get('source') ?? 'all';
const detailId = url.searchParams.get('detail');

let q = supabase
  .from('testimonials')
  .select('*')
  .eq('type', 'Testimonial')
  .order('date', { ascending: false, nullsFirst: false });
if (category !== 'all') q = q.eq('category', category);
if (source !== 'all') q = q.eq('source', source);

const { data: testimonials } = await q;
const { data: allMeta } = await supabase
  .from('testimonials')
  .select('category, source')
  .eq('type', 'Testimonial');
const categories = Array.from(new Set((allMeta ?? []).map((t) => t.category).filter(Boolean))).sort() as string[];
const sources = Array.from(new Set((allMeta ?? []).map((t) => t.source).filter(Boolean))).sort() as string[];

const detail = detailId ? (testimonials ?? []).find((t: any) => t.id === detailId) ?? null : null;

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';

const back = url.pathname + (url.search ? url.search.replace(/[?&]detail=[^&]*/, '').replace(/^&/, '?') : '');
const detailLink = (id: string) => {
  const params = new URLSearchParams(url.searchParams);
  params.set('detail', id);
  return `${url.pathname}?${params.toString()}`;
};
---
<AppLayout title="Testimonials · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-amber-100 grid place-items-center">
        <Quote class="text-amber-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Testimonials</h1>
        <p class="text-stone-500 text-sm">Feedback from members across the community</p>
      </div>
    </div>
  </header>

  <form method="GET" class="flex gap-2 mb-6">
    <select name="category" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={category === 'all'}>All categories</option>
      {categories.map((c) => <option value={c} selected={category === c}>{c}</option>)}
    </select>
    <select name="source" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={source === 'all'}>All sources</option>
      {sources.map((s) => <option value={s} selected={source === s}>{s}</option>)}
    </select>
  </form>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {testimonials && testimonials.length > 0 ? (
      testimonials.map((t: any) => {
        const body = (t.notes || t.rich_text || '').replace(/<[^>]+>/g, '').trim();
        return (
          <a
            href={detailLink(t.id)}
            class="block bg-white border border-stone-200 rounded-2xl p-5 hover:border-amber-300 hover:shadow-sm transition relative"
          >
            <Quote class="absolute top-4 right-4 text-amber-200" size={24} />
            {body ? (
              <p class="text-sm text-stone-700 line-clamp-6 pr-8">{body}</p>
            ) : (
              <p class="text-sm text-stone-400 italic">(no text preview — open to view)</p>
            )}
            <div class="mt-4 pt-3 border-t border-stone-100 flex items-center gap-2 text-xs text-stone-500">
              {t.from_username && <span class="font-medium text-stone-700">{t.from_username}</span>}
              {t.source && <span class="text-stone-400">· {t.source}</span>}
              {t.date && <span class="ml-auto flex items-center gap-1"><Calendar size={11} /> {fmt(t.date)}</span>}
            </div>
          </a>
        );
      })
    ) : (
      <div class="col-span-full bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
        No testimonials yet.
      </div>
    )}
  </div>

  {detail && (
    <div class="fixed inset-0 z-30">
      <a href={back} class="absolute inset-0 bg-black/30"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-2xl bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-5">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 text-xs">
              {detail.category && (
                <span class="font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded-full px-2 py-0.5">
                  {detail.category}
                </span>
              )}
              {detail.date && (
                <span class="text-stone-500 flex items-center gap-1"><Calendar size={12} /> {fmt(detail.date)}</span>
              )}
            </div>
            <a href={back} class="p-1 text-stone-400 hover:text-stone-700"><X size={20} /></a>
          </div>

          {detail.headline && <h1 class="text-2xl font-semibold text-stone-900">{detail.headline}</h1>}

          <div class="flex items-center gap-3 text-sm text-stone-500">
            {detail.from_username && (
              <span class="font-medium text-stone-800">{detail.from_username}</span>
            )}
            {detail.source && <span>· via {detail.source}</span>}
          </div>

          {detail.image_url && <img src={detail.image_url} alt="" class="w-full rounded-xl bg-stone-100" />}
          {detail.screenshot_url && detail.screenshot_url !== detail.image_url && (
            <img src={detail.screenshot_url} alt="" class="w-full rounded-xl bg-stone-100 border border-stone-200" />
          )}

          {(detail.rich_text || detail.notes) && (
            <div
              class="prose prose-sm max-w-none text-stone-700 [&_img]:max-h-64 [&_img]:w-auto [&_a]:text-amber-600"
              set:html={detail.rich_text || detail.notes}
            />
          )}

          {detail.video_url && (
            <a href={detail.video_url} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 text-sm text-amber-600 hover:text-amber-700 font-medium">
              ▶ Watch video <ExternalLink size={13} />
            </a>
          )}

          {detail.source_link && (
            <a href={detail.source_link} target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 text-sm text-amber-600 hover:text-amber-700 font-medium pt-2 border-t border-stone-100">
              Open source <ExternalLink size={14} />
            </a>
          )}
        </div>
      </aside>
    </div>
  )}
</AppLayout>
