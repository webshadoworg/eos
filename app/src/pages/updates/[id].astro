---
import AppLayout from '~/layouts/AppLayout.astro';
import { Calendar, ExternalLink, Pencil, ArrowLeft } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const { id } = Astro.params;

const { data: update } = await supabase
  .from('testimonials')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!update) return new Response('Not found', { status: 404 });

const isTestimonial = update.type === 'Testimonial';
const backHref = isTestimonial ? '/testimonials' : '/updates';
const backLabel = isTestimonial ? 'Testimonials' : 'Updates';

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '';

function youtubeEmbed(u: string | null): string | null {
  if (!u) return null;
  try {
    const parsed = new URL(u);
    const host = parsed.hostname.replace(/^www\./, '');
    if (host === 'youtu.be') return `https://www.youtube.com/embed/${parsed.pathname.slice(1)}`;
    if (host === 'youtube.com' || host === 'm.youtube.com') {
      const v = parsed.searchParams.get('v');
      if (v) return `https://www.youtube.com/embed/${v}`;
      if (parsed.pathname.startsWith('/embed/')) return u;
      if (parsed.pathname.startsWith('/shorts/')) return `https://www.youtube.com/embed/${parsed.pathname.split('/')[2]}`;
    }
  } catch {}
  return null;
}
function isDirectVideo(u: string | null): boolean {
  if (!u) return false;
  return /\.(mp4|webm|mov|m4v)(\?|$)/i.test(u);
}

const embed = youtubeEmbed(update.video_url);
---
<AppLayout title={`${update.headline || 'Update'} · GYE EOS`}>
  <div class="max-w-3xl mx-auto">
    <a href={backHref} class="inline-flex items-center gap-1.5 text-sm text-stone-500 hover:text-stone-900 mb-6">
      <ArrowLeft size={16} /> Back to {backLabel}
    </a>

    <article class="bg-white border border-stone-200 rounded-2xl overflow-hidden">
      {embed ? (
        <div class="aspect-video w-full bg-black">
          <iframe
            src={embed}
            class="w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        </div>
      ) : isDirectVideo(update.video_url) ? (
        <video controls class="w-full bg-black" src={update.video_url!} />
      ) : update.image_url ? (
        <img src={update.image_url} alt="" class="w-full max-h-[480px] object-cover bg-stone-100" />
      ) : update.screenshot_url ? (
        <img src={update.screenshot_url} alt="" class="w-full max-h-[480px] object-cover bg-stone-100" />
      ) : null}

      <div class="p-8 md:p-10">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3 text-sm">
            {update.category && (
              <span class="font-medium text-violet-700 bg-violet-50 border border-violet-200 rounded-full px-3 py-1">
                {update.category}
              </span>
            )}
            {update.date && (
              <span class="text-stone-500 flex items-center gap-1.5">
                <Calendar size={13} /> {fmt(update.date)}
              </span>
            )}
          </div>
          <a
            href={isTestimonial ? `/testimonials?detail=${update.id}` : `/updates?edit=${update.id}`}
            class="p-2 rounded-lg text-stone-500 hover:text-stone-900 hover:bg-stone-100"
            title="Edit"
          >
            <Pencil size={16} />
          </a>
        </div>

        <h1 class="text-3xl md:text-4xl font-semibold text-stone-900 leading-tight">
          {update.headline || 'Untitled update'}
        </h1>

        {(update.from_username || update.source) && (
          <div class="mt-4 text-sm text-stone-500">
            {update.from_username && <span class="font-medium text-stone-700">{update.from_username}</span>}
            {update.from_username && update.source && <span> · </span>}
            {update.source && <>via {update.source}</>}
          </div>
        )}

        {update.image_url && embed && (
          <img src={update.image_url} alt="" class="mt-6 w-full rounded-xl bg-stone-100" />
        )}
        {update.screenshot_url && update.screenshot_url !== update.image_url && (
          <img src={update.screenshot_url} alt="" class="mt-6 w-full rounded-xl bg-stone-100 border border-stone-200" />
        )}

        {(update.rich_text || update.notes) && (
          <div
            class="prose prose-stone max-w-none mt-6 [&_img]:rounded-lg [&_img]:max-h-96 [&_a]:text-violet-600"
            set:html={update.rich_text || update.notes}
          />
        )}

        {update.source_link && (
          <a href={update.source_link} target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 mt-8 text-sm text-violet-600 hover:text-violet-700 font-medium border-t border-stone-100 pt-6">
            Open source <ExternalLink size={14} />
          </a>
        )}
      </div>
    </article>
  </div>
</AppLayout>
