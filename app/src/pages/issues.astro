---
import AppLayout from '~/layouts/AppLayout.astro';
import StatusCheckbox from '~/components/StatusCheckbox.svelte';
import RichTextEditor from '~/components/RichTextEditor.svelte';
import { AlertCircle, Plus, Search, Zap, Clock, Lightbulb, Target, Archive, X, Trash2 } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
const team = Astro.locals.currentTeam;
const teams = Astro.locals.allowedTeams;
if (!team) return Astro.redirect('/');

const url = Astro.url;
const term = (url.searchParams.get('term') as 'short_term' | 'long_term' | 'idea_backlog') || 'short_term';
const statusFilter = url.searchParams.get('status') ?? 'active';
const ownerFilter = url.searchParams.get('owner') ?? 'all';
const sort = url.searchParams.get('sort') ?? 'manual';
const search = (url.searchParams.get('q') ?? '').trim();
const detailId = url.searchParams.get('detail');

const baseQuery = () =>
  supabase
    .from('issues')
    .select(
      'id, title, description, status, priority, priority_order, type, term_type, team_id, created_at, owner_employee_id, ' +
      'owner:employees!issues_owner_employee_id_fkey(id, full_name)',
    )
    .eq('team_id', team.id)
    .eq('term_type', term);

let q = baseQuery();
if (statusFilter === 'active') q = q.in('status', ['open', 'solved']);
else if (statusFilter !== 'all') q = q.eq('status', statusFilter);
if (ownerFilter !== 'all') q = q.eq('owner_employee_id', ownerFilter);
if (search) q = q.ilike('title', `%${search}%`);
if (sort === 'priority') q = q.order('priority', { ascending: true });
else if (sort === 'created') q = q.order('created_at', { ascending: false });
else q = q.order('priority_order', { ascending: true }).order('created_at', { ascending: false });

const [{ data: issues }, { data: employees }] = await Promise.all([
  q,
  supabase.from('employees').select('id, full_name').order('full_name'),
]);

let detail: any = null;
if (detailId) {
  const { data } = await baseQuery().eq('id', detailId).maybeSingle();
  detail = data;
}

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
const initials = (name: string) =>
  name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
const back = url.pathname + url.search;
const backNoDetail = url.pathname + (url.search ? url.search.replace(/[?&]detail=[^&]*/, '').replace(/^&/, '?') : '');
---
<AppLayout title="Issues · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-amber-100 grid place-items-center">
        <AlertCircle class="text-amber-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Issues</h1>
        <p class="text-stone-500 text-sm">{team.name} team issues</p>
      </div>
    </div>
    <div class="flex gap-2">
      <button disabled class="border border-stone-300 bg-white rounded-xl px-4 py-2.5 text-sm font-medium flex items-center gap-1.5 text-stone-500">
        <Target size={16} />
        Select Top 3
      </button>
      <a
        href={`/issues?term=${term}&status=archived`}
        class="border border-stone-300 bg-white rounded-xl px-4 py-2.5 text-sm font-medium flex items-center gap-1.5 text-stone-700"
      >
        <Archive size={16} />
        Archive
      </a>
    </div>
  </header>

  <div class="flex gap-6 border-b border-stone-200 mb-6">
    <a
      href="/issues?term=short_term"
      class={`flex items-center gap-1.5 pb-3 text-sm font-medium border-b-2 -mb-px ${
        term === 'short_term' ? 'border-violet-600 text-violet-700' : 'border-transparent text-stone-500'
      }`}
    >
      <Zap size={16} />
      Short Term
    </a>
    <a
      href="/issues?term=long_term"
      class={`flex items-center gap-1.5 pb-3 text-sm font-medium border-b-2 -mb-px ${
        term === 'long_term' ? 'border-violet-600 text-violet-700' : 'border-transparent text-stone-500'
      }`}
    >
      <Clock size={16} />
      Long Term
    </a>
    <a
      href="/issues?term=idea_backlog"
      class={`flex items-center gap-1.5 pb-3 text-sm font-medium border-b-2 -mb-px ${
        term === 'idea_backlog' ? 'border-violet-600 text-violet-700' : 'border-transparent text-stone-500'
      }`}
    >
      <Lightbulb size={16} />
      Idea Backlog
    </a>
  </div>

  <form method="POST" action="/api/issues" class="flex gap-2 mb-4">
    <input type="hidden" name="_action" value="create" />
    <input type="hidden" name="team_id" value={team.id} />
    <input type="hidden" name="term_type" value={term} />
    <input type="hidden" name="back" value={back} />
    <input
      type="text"
      name="title"
      placeholder="Add a new issue..."
      required
      class="flex-1 bg-white border border-stone-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-400"
    />
    <button class="bg-stone-800 hover:bg-stone-900 text-white rounded-xl px-5 py-3 text-sm font-medium flex items-center gap-1.5">
      <Plus size={16} />
      Add
    </button>
  </form>

  <form method="GET" class="flex gap-2 mb-4">
    <input type="hidden" name="term" value={term} />
    <div class="flex-1 relative">
      <Search size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" />
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Search issues..."
        class="w-full bg-white border border-stone-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-violet-400"
      />
    </div>
    <select name="status" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="active"   selected={statusFilter === 'active'}>Open &amp; Solved</option>
      <option value="open"     selected={statusFilter === 'open'}>Open only</option>
      <option value="solved"   selected={statusFilter === 'solved'}>Solved only</option>
      <option value="archived" selected={statusFilter === 'archived'}>Archived</option>
    </select>
    <select name="owner" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={ownerFilter === 'all'}>All People</option>
      {employees?.map((e) => <option value={e.id} selected={ownerFilter === e.id}>{e.full_name}</option>)}
    </select>
    <select name="sort" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="manual"   selected={sort === 'manual'}>Manual Order</option>
      <option value="priority" selected={sort === 'priority'}>Priority</option>
      <option value="created"  selected={sort === 'created'}>Created Date</option>
    </select>
  </form>

  <div class="bg-white border border-stone-200 rounded-xl divide-y divide-stone-100">
    {issues && issues.length > 0 ? (
      issues.map((i: any) => {
        const solved = i.status === 'solved';
        const detailHref = `?${new URLSearchParams({ ...Object.fromEntries(url.searchParams), detail: i.id }).toString()}`;
        return (
          <div class="flex items-center gap-3 px-4 py-3">
            <StatusCheckbox client:load id={i.id} status={i.status} endpoint="/api/issues" doneValue="solved" />
            <span class="text-xs font-semibold text-violet-600 bg-violet-50 border border-violet-200 rounded px-2 py-0.5 shrink-0">
              P{i.priority ?? 3}
            </span>
            <a
              href={detailHref}
              class={`flex-1 text-sm hover:text-violet-600 ${solved ? 'text-stone-400 line-through' : 'text-stone-800'}`}
            >
              {i.title}
            </a>
            {i.owner && (
              <div class="w-7 h-7 rounded-full bg-stone-100 text-stone-600 grid place-items-center text-[10px] font-semibold" title={i.owner.full_name}>
                {initials(i.owner.full_name)}
              </div>
            )}
            <div class="text-xs text-stone-400 w-12 text-right">{fmt(i.created_at)}</div>
          </div>
        );
      })
    ) : (
      <div class="px-4 py-12 text-center text-sm text-stone-400">
        No {term === 'short_term' ? 'short-term' : term === 'long_term' ? 'long-term' : 'idea backlog'} issues matching the filters.
      </div>
    )}
  </div>

  {detail && (
    <div class="fixed inset-0 z-30">
      <a href={backNoDetail} class="absolute inset-0 bg-black/20"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-5">
          <div class="flex items-center justify-between">
            <span class="inline-block text-xs font-medium text-stone-600 bg-stone-100 rounded-full px-2.5 py-1">{team.name}</span>
            <a href={backNoDetail} class="p-1 text-stone-400 hover:text-stone-700"><X size={18} /></a>
          </div>
          <h2 class="text-xl font-semibold text-stone-900">Issue Details</h2>

          <div class="flex gap-2">
            <form method="POST" action="/api/issues">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="status" value={detail.status === 'solved' ? 'open' : 'solved'} />
              <input type="hidden" name="title" value={detail.title} />
              <input type="hidden" name="term_type" value={detail.term_type} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-emerald-300 text-emerald-700 bg-emerald-50 rounded-lg px-3 py-1.5 text-sm font-medium">
                ✓ {detail.status === 'solved' ? 'Mark Open' : 'Mark Solved'}
              </button>
            </form>
            <form method="POST" action="/api/issues">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="status" value="archived" />
              <input type="hidden" name="title" value={detail.title} />
              <input type="hidden" name="term_type" value={detail.term_type} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-stone-300 text-stone-700 rounded-lg px-3 py-1.5 text-sm font-medium">
                <Archive size={14} /> Archive
              </button>
            </form>
            <form method="POST" action="/api/issues">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-rose-300 text-rose-700 rounded-lg px-3 py-1.5 text-sm font-medium">
                <Trash2 size={14} /> Delete
              </button>
            </form>
          </div>

          <form method="POST" action="/api/issues" class="space-y-4">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={detail.id} />
            <input type="hidden" name="back" value={backNoDetail} />

            <div>
              <label class="text-sm font-medium text-stone-700">Title</label>
              <input type="text" name="title" value={detail.title}
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Description</label>
              <div class="mt-1">
                <RichTextEditor
                  client:only="svelte"
                  name="description"
                  initial={detail.description ?? ''}
                  autosaveUrl="/api/issues"
                  autosaveId={detail.id}
                />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-sm font-medium text-stone-700">Priority</label>
                <select name="priority" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                  {[1, 2, 3, 4, 5].map((p) => <option value={p} selected={p === detail.priority}>P{p}</option>)}
                </select>
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Type</label>
                <select name="type" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                  <option value="">—</option>
                  {['problem', 'idea', 'question', 'brainstorm', 'update'].map((t) => (
                    <option value={t} selected={t === detail.type}>{t}</option>
                  ))}
                </select>
              </div>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Team</label>
              <select name="team_id" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                {teams.map((t) => <option value={t.id} selected={t.id === detail.team_id}>{t.name}</option>)}
              </select>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Owner</label>
              <select name="owner_employee_id" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                <option value="">Unassigned</option>
                {employees?.map((e) => <option value={e.id} selected={e.id === detail.owner_employee_id}>{e.full_name}</option>)}
              </select>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Term</label>
              <select name="term_type" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                <option value="short_term" selected={detail.term_type === 'short_term'}>Short term</option>
                <option value="long_term" selected={detail.term_type === 'long_term'}>Long term</option>
                <option value="idea_backlog" selected={detail.term_type === 'idea_backlog'}>Idea Backlog</option>
              </select>
            </div>

            <button class="w-full bg-violet-600 hover:bg-violet-700 text-white rounded-lg py-2.5 text-sm font-medium">
              Save changes
            </button>
          </form>
        </div>
      </aside>
    </div>
  )}
</AppLayout>
