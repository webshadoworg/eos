---
import AppLayout from '~/layouts/AppLayout.astro';
import { Plane, Plus, Trash2, MapPin, Calendar } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const { data: trips } = await supabase
  .from('trips')
  .select('*')
  .order('start_date', { ascending: false, nullsFirst: false });

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
const back = '/trips';
---
<AppLayout title="Trips · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-sky-100 grid place-items-center">
        <Plane class="text-sky-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Trips</h1>
        <p class="text-stone-500 text-sm">Who's traveling where</p>
      </div>
    </div>
  </header>

  <form method="POST" action="/api/trips" class="bg-white border border-stone-200 rounded-2xl p-5 mb-6">
    <input type="hidden" name="_action" value="create" />
    <input type="hidden" name="back" value={back} />
    <div class="flex items-center gap-2 text-sm font-semibold text-stone-700 mb-4">
      <Plus size={16} /> Add a new trip
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div class="md:col-span-2">
        <label class="text-xs font-medium text-stone-500 uppercase">City</label>
        <input type="text" name="city" required
          class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-400" />
      </div>
      <div>
        <label class="text-xs font-medium text-stone-500 uppercase">Start date</label>
        <input type="date" name="start_date"
          class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="text-xs font-medium text-stone-500 uppercase">End date</label>
        <input type="date" name="end_date"
          class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm" />
      </div>
      <div class="md:col-span-2">
        <label class="text-xs font-medium text-stone-500 uppercase">People (comma-separated)</label>
        <input type="text" name="people" placeholder="Mendy, Yaakov, Florin"
          class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm" />
      </div>
      <div class="md:col-span-2">
        <label class="text-xs font-medium text-stone-500 uppercase">Notes</label>
        <textarea name="notes" rows="2"
          class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm"></textarea>
      </div>
    </div>
    <button class="mt-4 bg-sky-600 hover:bg-sky-700 text-white rounded-lg px-5 py-2 text-sm font-medium">
      Save trip
    </button>
  </form>

  <div class="grid gap-3">
    {trips && trips.length > 0 ? (
      trips.map((t: any) => (
        <div class="bg-white border border-stone-200 rounded-2xl p-5 flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 text-stone-900 font-semibold">
              <MapPin size={16} class="text-sky-600" /> {t.city}
            </div>
            {(t.start_date || t.end_date) && (
              <div class="flex items-center gap-1.5 text-sm text-stone-500 mt-1">
                <Calendar size={13} />
                {fmt(t.start_date)}{t.end_date && ` → ${fmt(t.end_date)}`}
              </div>
            )}
            {t.people && t.people.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {t.people.map((p: string) => (
                  <span class="text-xs bg-stone-50 border border-stone-200 rounded-full px-2.5 py-0.5 text-stone-700">{p}</span>
                ))}
              </div>
            )}
            {t.notes && <p class="text-sm text-stone-500 mt-3 whitespace-pre-wrap">{t.notes}</p>}
          </div>
          <form method="POST" action="/api/trips">
            <input type="hidden" name="_action" value="delete" />
            <input type="hidden" name="id" value={t.id} />
            <input type="hidden" name="back" value={back} />
            <button class="p-2 text-stone-400 hover:text-rose-600 rounded-lg hover:bg-rose-50" title="Delete">
              <Trash2 size={15} />
            </button>
          </form>
        </div>
      ))
    ) : (
      <div class="bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
        No trips yet. Add one above.
      </div>
    )}
  </div>
</AppLayout>
