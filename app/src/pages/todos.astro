---
import AppLayout from '~/layouts/AppLayout.astro';
import StatusCheckbox from '~/components/StatusCheckbox.svelte';
import RichTextEditor from '~/components/RichTextEditor.svelte';
import { CheckSquare, Plus, Search, Flag, X, Trash2, Archive } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
const team = Astro.locals.currentTeam;
const teams = Astro.locals.allowedTeams;
if (!team) return Astro.redirect('/');

const url = Astro.url;
const statusFilter = url.searchParams.get('status') ?? 'active'; // active | open | done | archived | all
const assigneeFilter = url.searchParams.get('assignee') ?? 'all';
const sort = url.searchParams.get('sort') ?? 'created';
const search = (url.searchParams.get('q') ?? '').trim();
const detailId = url.searchParams.get('detail');

const baseQuery = () =>
  supabase
    .from('todos')
    .select(
      'id, title, description, status, is_urgent, due_date, created_at, team_id, assignee_employee_id, ' +
      'assignee:employees!todos_assignee_employee_id_fkey(id, full_name, email)',
    )
    .eq('team_id', team.id);

let q = baseQuery();
if (statusFilter === 'active') q = q.in('status', ['open', 'done']);
else if (statusFilter !== 'all') q = q.eq('status', statusFilter);
if (assigneeFilter !== 'all') q = q.eq('assignee_employee_id', assigneeFilter);
if (search) q = q.ilike('title', `%${search}%`);
if (sort === 'due') q = q.order('due_date', { ascending: true, nullsFirst: false });
else if (sort === 'title') q = q.order('title', { ascending: true });
else q = q.order('created_at', { ascending: false });

const [{ data: todos }, { data: employees }] = await Promise.all([
  q,
  supabase.from('employees').select('id, full_name').order('full_name'),
]);

let detail: any = null;
if (detailId) {
  const { data } = await baseQuery().eq('id', detailId).maybeSingle();
  detail = data;
}

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
const initials = (name: string) =>
  name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
const back = Astro.url.pathname + Astro.url.search;
const backNoDetail = Astro.url.pathname + (Astro.url.search ? Astro.url.search.replace(/[?&]detail=[^&]*/, '').replace(/^&/, '?') : '');
---
<AppLayout title="To-Dos · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-violet-100 grid place-items-center">
        <CheckSquare class="text-violet-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">To-Dos</h1>
        <p class="text-stone-500 text-sm">{team.name} team to-dos</p>
      </div>
    </div>
    <a
      href={`/todos?status=archived`}
      class="border border-stone-300 bg-white rounded-xl px-4 py-2.5 text-sm font-medium flex items-center gap-1.5 text-stone-700 hover:bg-stone-50"
    >
      <Archive size={16} />
      Archive
    </a>
  </header>

  <form method="POST" action="/api/todos" class="flex gap-2 mb-4">
    <input type="hidden" name="_action" value="create" />
    <input type="hidden" name="team_id" value={team.id} />
    <input type="hidden" name="back" value={back} />
    <input
      type="text"
      name="title"
      placeholder="Add a new to-do..."
      required
      class="flex-1 bg-white border border-stone-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-400"
    />
    <select name="assignee_employee_id" class="bg-white border border-stone-200 rounded-xl px-3 py-3 text-sm">
      <option value="">Unassigned</option>
      {employees?.map((e) => <option value={e.id}>{e.full_name}</option>)}
    </select>
    <button class="bg-stone-800 hover:bg-stone-900 text-white rounded-xl px-5 py-3 text-sm font-medium flex items-center gap-1.5">
      <Plus size={16} />
      Add
    </button>
  </form>

  <form method="GET" class="flex gap-2 mb-4">
    <div class="flex-1 relative">
      <Search size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" />
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Search to-dos..."
        class="w-full bg-white border border-stone-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-violet-400"
      />
    </div>
    <select name="status" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="active"   selected={statusFilter === 'active'}>Open &amp; Done</option>
      <option value="open"     selected={statusFilter === 'open'}>Open only</option>
      <option value="done"     selected={statusFilter === 'done'}>Done only</option>
      <option value="archived" selected={statusFilter === 'archived'}>Archived</option>
      <option value="all"      selected={statusFilter === 'all'}>All</option>
    </select>
    <select name="assignee" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={assigneeFilter === 'all'}>All Assignees</option>
      {employees?.map((e) => <option value={e.id} selected={assigneeFilter === e.id}>{e.full_name}</option>)}
    </select>
    <select name="sort" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="created" selected={sort === 'created'}>Created Date</option>
      <option value="due"     selected={sort === 'due'}>Due Date</option>
      <option value="title"   selected={sort === 'title'}>Title</option>
    </select>
  </form>

  <div class="bg-white border border-stone-200 rounded-xl divide-y divide-stone-100">
    {todos && todos.length > 0 ? (
      todos.map((t: any) => {
        const done = t.status === 'done';
        const detailHref = `?${new URLSearchParams({ ...Object.fromEntries(url.searchParams), detail: t.id }).toString()}`;
        return (
          <div class="flex items-center gap-3 px-4 py-3 group">
            <StatusCheckbox client:load id={t.id} status={t.status} endpoint="/api/todos" />
            <a
              href={detailHref}
              class={`flex-1 text-sm hover:text-violet-600 ${done ? 'text-stone-400 line-through' : 'text-stone-800'}`}
            >
              {t.title}
            </a>
            {t.is_urgent && <Flag size={14} class="text-rose-500" />}
            {t.assignee && (
              <div class="flex items-center gap-1.5 text-xs text-stone-500">
                <div class="w-6 h-6 rounded-full bg-violet-100 text-violet-700 grid place-items-center text-[10px] font-semibold">
                  {initials(t.assignee.full_name)}
                </div>
                <span class="text-rose-500 font-medium">{t.assignee.full_name.split(' ')[0]}</span>
                {t.due_date && <span class="text-rose-500">{fmt(t.due_date)}</span>}
              </div>
            )}
            <div class="text-xs text-stone-400 w-12 text-right">{fmt(t.created_at)}</div>
            <form method="POST" action="/api/todos" class="opacity-0 group-hover:opacity-100 transition">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={t.id} />
              <input type="hidden" name="title" value={t.title} />
              <input type="hidden" name="status" value={t.status === 'archived' ? 'open' : 'archived'} />
              <input type="hidden" name="back" value={back} />
              <button
                class="p-1.5 rounded text-stone-400 hover:text-stone-800 hover:bg-stone-100"
                title={t.status === 'archived' ? 'Unarchive' : 'Archive'}
              >
                <Archive size={14} />
              </button>
            </form>
          </div>
        );
      })
    ) : (
      <div class="px-4 py-12 text-center text-sm text-stone-400">No to-dos matching the filters.</div>
    )}
  </div>

  {detail && (
    <div class="fixed inset-0 z-30">
      <a href={backNoDetail} class="absolute inset-0 bg-black/20"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-5">
          <div class="flex items-center justify-between">
            <span class="inline-block text-xs font-medium text-stone-600 bg-stone-100 rounded-full px-2.5 py-1">
              {team.name}
            </span>
            <a href={backNoDetail} class="p-1 text-stone-400 hover:text-stone-700"><X size={18} /></a>
          </div>
          <h2 class="text-xl font-semibold text-stone-900">To-Do Details</h2>

          <div class="flex gap-2">
            <form method="POST" action="/api/todos">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="status" value={detail.status === 'done' ? 'open' : 'done'} />
              <input type="hidden" name="title" value={detail.title} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-emerald-300 text-emerald-700 bg-emerald-50 rounded-lg px-3 py-1.5 text-sm font-medium">
                ✓ {detail.status === 'done' ? 'Mark Open' : 'Mark Done'}
              </button>
            </form>
            <form method="POST" action="/api/todos">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="status" value="archived" />
              <input type="hidden" name="title" value={detail.title} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-stone-300 text-stone-700 rounded-lg px-3 py-1.5 text-sm font-medium">
                <Archive size={14} /> Archive
              </button>
            </form>
            <form method="POST" action="/api/todos">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={detail.id} />
              <input type="hidden" name="back" value={backNoDetail} />
              <button class="flex items-center gap-1.5 border border-rose-300 text-rose-700 rounded-lg px-3 py-1.5 text-sm font-medium">
                <Trash2 size={14} /> Delete
              </button>
            </form>
          </div>

          <form method="POST" action="/api/todos" class="space-y-4">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={detail.id} />
            <input type="hidden" name="back" value={backNoDetail} />

            <div>
              <label class="text-sm font-medium text-stone-700">Title</label>
              <input type="text" name="title" value={detail.title}
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Description</label>
              <div class="mt-1">
                <RichTextEditor
                  client:only="svelte"
                  name="description"
                  initial={detail.description ?? ''}
                  autosaveUrl="/api/todos"
                  autosaveId={detail.id}
                />
              </div>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Team</label>
              <select name="team_id" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                {teams.map((t) => <option value={t.id} selected={t.id === detail.team_id}>{t.name}</option>)}
              </select>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Assignee</label>
              <select name="assignee_employee_id" class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm">
                <option value="">Unassigned</option>
                {employees?.map((e) => <option value={e.id} selected={e.id === detail.assignee_employee_id}>{e.full_name}</option>)}
              </select>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Due Date</label>
              <input type="date" name="due_date" value={detail.due_date ?? ''}
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm" />
            </div>

            <label class="flex items-center gap-2 text-sm text-stone-700">
              <input type="checkbox" name="is_urgent" checked={detail.is_urgent} />
              Urgent
            </label>

            <button class="w-full bg-violet-600 hover:bg-violet-700 text-white rounded-lg py-2.5 text-sm font-medium">
              Save changes
            </button>
          </form>
        </div>
      </aside>
    </div>
  )}
</AppLayout>
