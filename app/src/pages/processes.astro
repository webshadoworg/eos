---
import AppLayout from '~/layouts/AppLayout.astro';
import { BookOpen, Search } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
const team = Astro.locals.currentTeam;
const allowedTeamIds = Astro.locals.allowedTeams.map((t) => t.id);
const search = (Astro.url.searchParams.get('q') ?? '').trim();

// Processes: show current team if selected, else all allowed teams
let q = supabase.from('processes').select('*, team:teams(id, name)').eq('is_archived', false).order('name');
if (team) q = q.eq('team_id', team.id);
else if (allowedTeamIds.length) q = q.in('team_id', allowedTeamIds);
else q = q.eq('team_id', '__none__'); // force empty result
if (search) q = q.ilike('name', `%${search}%`);
const { data: processes } = await q;
---
<AppLayout title="Processes · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-indigo-100 grid place-items-center">
        <BookOpen class="text-indigo-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Processes</h1>
        <p class="text-stone-500 text-sm">{team ? `${team.name} playbooks` : 'Team playbooks and SOPs'}</p>
      </div>
    </div>
  </header>

  <form method="GET" class="mb-6">
    <div class="relative">
      <Search size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" />
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Search processes..."
        class="w-full bg-white border border-stone-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-indigo-400"
      />
    </div>
  </form>

  <div class="space-y-3">
    {processes && processes.length > 0 ? (
      processes.map((p: any) => (
        <details class="bg-white border border-stone-200 rounded-2xl group">
          <summary class="list-none cursor-pointer px-5 py-4 flex items-center justify-between">
            <span class="font-medium text-stone-900">{p.name}</span>
            <span class="text-xs text-stone-400 group-open:rotate-90 transition">▸</span>
          </summary>
          {p.details && (
            <div
              class="px-5 pb-5 pt-4 border-t border-stone-100 prose prose-sm max-w-none text-stone-600"
              set:html={p.details}
            />
          )}
        </details>
      ))
    ) : (
      <div class="bg-white border border-stone-200 rounded-xl px-4 py-12 text-center text-sm text-stone-400">
        No processes yet.
      </div>
    )}
  </div>
</AppLayout>
