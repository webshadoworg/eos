---
import AppLayout from '~/layouts/AppLayout.astro';
import VtoEditor from '~/components/VtoEditor.svelte';
import { Eye, Pencil, Check } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
import { canEditVto } from '~/lib/permissions';

const user = Astro.locals.user;
const canEdit = canEditVto(user?.email);
const editMode = canEdit && Astro.url.searchParams.get('edit') === '1';

const { data: vto } = await supabase
  .from('vtos')
  .select('id, vision, traction, swot')
  .limit(1)
  .maybeSingle();

const vision = vto?.vision ?? {};
const traction = vto?.traction ?? {};
const swot = vto?.swot ?? {};
---
<AppLayout title="V/TO · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-violet-100 grid place-items-center">
        <Eye class="text-violet-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Vision/Traction Organizer</h1>
        <p class="text-stone-500 text-sm">
          {editMode
            ? 'Editing — changes autosave.'
            : 'The one-page plan for GYE.'}
        </p>
      </div>
    </div>
    {canEdit && (
      editMode ? (
        <a
          href="/vto"
          class="bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl px-5 py-2.5 text-sm font-medium flex items-center gap-1.5"
        >
          <Check size={16} />
          Done editing
        </a>
      ) : (
        <a
          href="/vto?edit=1"
          class="border border-stone-300 bg-white hover:bg-stone-50 text-stone-700 rounded-xl px-5 py-2.5 text-sm font-medium flex items-center gap-1.5"
        >
          <Pencil size={16} />
          Edit V/TO
        </a>
      )
    )}
  </header>

  <VtoEditor
    client:only="svelte"
    initialVision={vision}
    initialTraction={traction}
    initialSwot={swot}
    readOnly={!editMode}
  />
</AppLayout>
