---
import AppLayout from '~/layouts/AppLayout.astro';
import { Focus as FocusIcon } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
const team = Astro.locals.currentTeam;
if (!team) return Astro.redirect('/');

const { data: memberships } = await supabase
  .from('team_memberships')
  .select('id, role, role_description, display_order, employee:employees(id, full_name, email)')
  .eq('team_id', team.id)
  .order('display_order');

const { data: focuses } = await supabase
  .from('current_focuses')
  .select('id, employee_id, focus_text')
  .eq('team_id', team.id);

const focusByEmployee = new Map<string, { id: string; focus_text: string }>();
for (const f of focuses ?? []) {
  if (f.employee_id) focusByEmployee.set(f.employee_id, { id: f.id, focus_text: f.focus_text });
}

const back = '/focus';
---
<AppLayout title="Current Focus · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-amber-100 grid place-items-center">
        <FocusIcon class="text-amber-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">{team.name} — Current Focus</h1>
        <p class="text-stone-500 text-sm">Updated live during meetings, reviewed week-to-week</p>
      </div>
    </div>
  </header>

  <div class="bg-white border border-stone-200 rounded-2xl overflow-hidden">
    <div class="grid grid-cols-[1fr_2fr] bg-stone-50 px-5 py-3 text-xs font-semibold text-stone-500 uppercase tracking-wider">
      <div>Team Member</div>
      <div>Current Focus</div>
    </div>
    {memberships && memberships.length > 0 ? (
      memberships.map((m: any) => {
        const current = m.employee ? focusByEmployee.get(m.employee.id) : null;
        return (
          <div class="grid grid-cols-[1fr_2fr] border-t border-stone-100 px-5 py-4 items-center">
            <div>
              <div class="text-sm font-medium text-stone-800">{m.employee?.full_name}</div>
              {m.role_description && <div class="text-xs text-stone-500 mt-0.5">{m.role_description}</div>}
            </div>
            {m.employee && (
              <form method="POST" action="/api/focus" class="flex gap-2">
                <input type="hidden" name="_action" value="upsert" />
                <input type="hidden" name="team_id" value={team.id} />
                <input type="hidden" name="employee_id" value={m.employee.id} />
                <input type="hidden" name="existing_id" value={current?.id ?? ''} />
                <input type="hidden" name="back" value={back} />
                <input
                  type="text"
                  name="focus_text"
                  value={current?.focus_text ?? ''}
                  placeholder="Enter current focus..."
                  onblur="this.form.submit()"
                  class="flex-1 bg-transparent border-b border-transparent hover:border-stone-200 focus:border-amber-400 focus:outline-none text-sm text-stone-800 py-1"
                />
              </form>
            )}
          </div>
        );
      })
    ) : (
      <div class="px-5 py-12 text-center text-sm text-stone-400">No members in this team.</div>
    )}
  </div>

  <div class="mt-10">
    <h2 class="text-lg font-semibold text-stone-900 mb-4">Team Roles</h2>
    <div class="space-y-4">
      {memberships?.filter((m: any) => m.role_description).map((m: any) => (
        <div class="bg-white border border-stone-200 rounded-2xl p-5">
          <div class="font-semibold text-stone-900">{m.employee?.full_name}</div>
          <div class="prose prose-sm max-w-none text-stone-600 mt-2" set:html={m.role_description} />
        </div>
      ))}
    </div>
  </div>
</AppLayout>
