---
import AppLayout from '~/layouts/AppLayout.astro';
import { Contact, Search, Mail, Phone, MapPin, Globe } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const url = Astro.url;
const search = (url.searchParams.get('q') ?? '').trim();
const category = url.searchParams.get('category') ?? 'all';

let q = supabase
  .from('contacts')
  .select('*')
  .eq('is_private', false)
  .order('name');
if (search) q = q.ilike('name', `%${search}%`);
if (category !== 'all') q = q.eq('category', category);

const { data: contacts } = await q;
const { data: allForCategories } = await supabase.from('contacts').select('category');
const categories = Array.from(
  new Set((allForCategories ?? []).map((c) => c.category).filter(Boolean)),
).sort() as string[];

const initials = (name: string) =>
  name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
---
<AppLayout title="Directory · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-sky-100 grid place-items-center">
        <Contact class="text-sky-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Directory</h1>
        <p class="text-stone-500 text-sm">People and contacts across GYE</p>
      </div>
    </div>
  </header>

  <form method="GET" class="flex gap-2 mb-6">
    <div class="flex-1 relative">
      <Search size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" />
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Search by name..."
        class="w-full bg-white border border-stone-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-sky-400"
      />
    </div>
    <select name="category" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={category === 'all'}>All categories</option>
      {categories.map((c) => <option value={c} selected={category === c}>{c}</option>)}
    </select>
  </form>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {contacts && contacts.length > 0 ? (
      contacts.map((c: any) => (
        <div class="bg-white border border-stone-200 rounded-2xl p-5 hover:border-stone-300 transition">
          <div class="flex items-start gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-violet-100 to-sky-100 text-stone-700 grid place-items-center text-sm font-semibold">
              {initials(c.name)}
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-stone-900 truncate">{c.name}</div>
              {c.category && <div class="text-xs text-stone-500">{c.category}</div>}
              {c.nicknames && <div class="text-xs text-stone-400 italic truncate">{c.nicknames}</div>}
            </div>
          </div>
          <div class="space-y-1.5 text-sm">
            {c.private_email && (
              <a href={`mailto:${c.private_email}`} class="flex items-center gap-2 text-stone-600 hover:text-sky-600 truncate">
                <Mail size={14} class="shrink-0" /> <span class="truncate">{c.private_email}</span>
              </a>
            )}
            {c.private_cell_number && (
              <a href={`tel:${c.private_cell_number}`} class="flex items-center gap-2 text-stone-600 hover:text-sky-600">
                <Phone size={14} class="shrink-0" /> {c.private_cell_number}
              </a>
            )}
            {c.location && (
              <div class="flex items-center gap-2 text-stone-600">
                <MapPin size={14} class="shrink-0" /> {c.location}
              </div>
            )}
            {c.gye_username && (
              <div class="flex items-center gap-2 text-stone-500">
                <Globe size={14} class="shrink-0" /> {c.gye_username}
              </div>
            )}
          </div>
          {c.about && <p class="mt-3 pt-3 border-t border-stone-100 text-xs text-stone-500 line-clamp-3">{c.about}</p>}
        </div>
      ))
    ) : (
      <div class="col-span-full bg-white border border-stone-200 rounded-xl px-4 py-12 text-center text-sm text-stone-400">
        No contacts matching the filters.
      </div>
    )}
  </div>
</AppLayout>
