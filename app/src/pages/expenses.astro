---
import AppLayout from '~/layouts/AppLayout.astro';
import { Wallet, Calendar, ChevronRight, CreditCard, X, AlertCircle, CircleHelp, Store, ClipboardList, MessageSquare } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';
import { resolveMethodFilter } from '~/lib/expense-method';
import { canAccessExpenses } from '~/lib/permissions';

if (!canAccessExpenses(Astro.locals)) {
  return new Response('Forbidden — Finance team members only', { status: 403 });
}

const methodFilter = resolveMethodFilter(Astro.url, Astro.cookies);

let expQuery = supabase.from('expenses').select('expense_id, month, amount, method, status');
if (methodFilter) expQuery = expQuery.eq('method', methodFilter);
const { data: expenses } = await expQuery;

// Pull methods so we can show the filter chip with label + owner info
const { data: methods } = await supabase
  .from('expense_methods')
  .select('name, label, employee:employees(id, full_name)');

const methodByName = new Map<string, { label: string | null; ownerName: string | null }>();
for (const m of (methods ?? []) as any[]) {
  const employee = Array.isArray(m.employee) ? m.employee[0] : m.employee;
  methodByName.set(m.name, {
    label: m.label,
    ownerName: employee?.full_name ?? null,
  });
}
const activeMethodMeta = methodFilter ? methodByName.get(methodFilter) : null;

type Row = { month: string; amount: string | number };
const groupsByMonth = new Map<string, { month: string; label: string; total: number; count: number }>();
for (const e of (expenses ?? []) as Row[]) {
  const m = e.month;
  if (!groupsByMonth.has(m)) {
    const [yyyy, mm] = m.split('-').map(Number);
    const label = new Date(Date.UTC(yyyy, (mm ?? 1) - 1, 1)).toLocaleDateString('en-US', {
      month: 'long',
      year: 'numeric',
      timeZone: 'UTC',
    });
    groupsByMonth.set(m, { month: m, label, total: 0, count: 0 });
  }
  const g = groupsByMonth.get(m)!;
  g.total += Number(e.amount) || 0;
  g.count += 1;
}
const groups = Array.from(groupsByMonth.values()).sort((a, b) => b.month.localeCompare(a.month));

// ────────────────────────────────────────────────────────────────
// Stats strip: unapproved spend, unreviewed/flagged counts, vendors with open notes.
// ────────────────────────────────────────────────────────────────
const allExpenses = (expenses ?? []) as { expense_id: number; amount: string | number; status: string }[];
const unreviewed = allExpenses.filter((e) => e.status === 'none');
const flagged = allExpenses.filter((e) => e.status === 'to_review');
const toMove = allExpenses.filter((e) => e.status === 'to_move');
const unapproved = [...unreviewed, ...flagged, ...toMove];
const unapprovedTotal = unapproved.reduce((s, e) => s + (Number(e.amount) || 0), 0);

// Charges with expense_notes (user wants to see where narrative context lives).
let chargesWithNotes = 0;
const expenseIds = allExpenses.map((e) => e.expense_id);
if (expenseIds.length > 0) {
  const { data: noteRows } = await supabase
    .from('expense_notes')
    .select('expense_id')
    .in('expense_id', expenseIds);
  chargesWithNotes = new Set((noteRows ?? []).map((r: any) => r.expense_id)).size;
}

// Vendor notes: description / latest_update / to_do / review_again set.
const { data: vendorRows } = await supabase
  .from('expenses_vendors')
  .select('vendor_id, description, latest_update, to_do, review_again');
const today = new Date().toISOString().slice(0, 10);
const vendorsWithTodo = (vendorRows ?? []).filter((v: any) => (v.to_do ?? '').trim()).length;
const vendorsDueReview = (vendorRows ?? []).filter((v: any) => v.review_again && v.review_again <= today).length;
const vendorsWithNotes = (vendorRows ?? []).filter((v: any) =>
  (v.description ?? '').trim() ||
  (v.latest_update ?? '').trim() ||
  (v.to_do ?? '').trim() ||
  (v.review_again ?? '').trim()
).length;

const reviewMethodQs = methodFilter ? `&method=${encodeURIComponent(methodFilter)}` : '';
const unapprovedHref = `/expenses/review${methodFilter ? `?method=${encodeURIComponent(methodFilter)}` : ''}`;
const flaggedHref = `/expenses/review?status=to_review${reviewMethodQs}`;

const fmtMoney = (n: number) =>
  '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---
<AppLayout title="Expenses · GYE EOS">
  <header class="flex items-start justify-between mb-6">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-emerald-100 grid place-items-center">
        <Wallet class="text-emerald-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Expenses</h1>
        <p class="text-stone-500 text-sm">Monthly spend reports</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <a
        href="/expenses/vendors"
        class="border border-stone-300 bg-white rounded-xl px-4 py-2.5 text-sm font-medium flex items-center gap-1.5 text-stone-700 hover:bg-stone-50"
      >
        <Store size={16} />
        Vendors
      </a>
      <a
        href="/expenses/methods"
        class="border border-stone-300 bg-white rounded-xl px-4 py-2.5 text-sm font-medium flex items-center gap-1.5 text-stone-700 hover:bg-stone-50"
      >
        <CreditCard size={16} />
        Methods
      </a>
    </div>
  </header>

  {/* Stats strip */}
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <a
      href={unapprovedHref}
      class="group bg-white border border-stone-200 rounded-2xl p-4 hover:border-amber-300 hover:shadow-sm transition block"
    >
      <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-wide">
        <AlertCircle size={14} class="text-amber-500" />
        Unapproved spend
      </div>
      <div class="mt-2 text-2xl font-semibold text-stone-900 tabular-nums">{fmtMoney(unapprovedTotal)}</div>
      <div class="text-[11px] text-stone-500 mt-0.5">
        {unapproved.length} charge{unapproved.length === 1 ? '' : 's'} · {unreviewed.length} new · {flagged.length} flagged{toMove.length > 0 ? ` · ${toMove.length} to move` : ''}
      </div>
    </a>

    <a
      href={flaggedHref}
      class="group bg-white border border-stone-200 rounded-2xl p-4 hover:border-amber-300 hover:shadow-sm transition block"
    >
      <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-wide">
        <CircleHelp size={14} class="text-amber-500" />
        Flagged for review
      </div>
      <div class="mt-2 text-2xl font-semibold text-stone-900 tabular-nums">{flagged.length}</div>
      <div class="text-[11px] text-stone-500 mt-0.5">charges marked to re-examine</div>
    </a>

    <a
      href="/expenses/vendors"
      class="group bg-white border border-stone-200 rounded-2xl p-4 hover:border-purple-300 hover:shadow-sm transition block"
    >
      <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-wide">
        <ClipboardList size={14} class="text-purple-500" />
        Vendors with notes
      </div>
      <div class="mt-2 text-2xl font-semibold text-stone-900 tabular-nums">{vendorsWithNotes}</div>
      <div class="text-[11px] text-stone-500 mt-0.5">
        {vendorsWithTodo} with to-do{vendorsDueReview > 0 ? ` · ${vendorsDueReview} due for review` : ''}
      </div>
    </a>

    <div class="bg-white border border-stone-200 rounded-2xl p-4">
      <div class="flex items-center gap-2 text-xs font-medium text-stone-500 uppercase tracking-wide">
        <MessageSquare size={14} class="text-violet-500" />
        Charges with notes
      </div>
      <div class="mt-2 text-2xl font-semibold text-stone-900 tabular-nums">{chargesWithNotes}</div>
      <div class="text-[11px] text-stone-500 mt-0.5">charges annotated by Finance</div>
    </div>
  </div>

  {methodFilter && (
    <div class="mb-6 bg-sky-50 border border-sky-200 rounded-xl px-4 py-3 flex items-center gap-3">
      <CreditCard size={16} class="text-sky-600" />
      <div class="flex-1 text-sm text-sky-900">
        Filtering by <span class="font-mono font-semibold">{methodFilter}</span>
        {activeMethodMeta?.label && <> · {activeMethodMeta.label}</>}
        {activeMethodMeta?.ownerName && <> · owned by <span class="font-medium">{activeMethodMeta.ownerName}</span></>}
      </div>
      <a
        href="/expenses?method=all"
        class="inline-flex items-center gap-1 text-xs text-sky-700 hover:text-sky-900 font-medium"
      >
        <X size={13} /> Clear
      </a>
    </div>
  )}

  {groups.length === 0 ? (
    <div class="bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
      {methodFilter ? 'No expenses for this method yet.' : 'No expenses yet.'}
    </div>
  ) : (
    <div class="grid gap-3">
      {groups.map((g) => (
        <a
          href={`/expenses/${g.month}`}
          class="group bg-white border border-stone-200 rounded-2xl px-6 py-5 flex items-center justify-between hover:border-emerald-300 hover:shadow-sm transition"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-700 grid place-items-center">
              <Calendar size={18} />
            </div>
            <div>
              <div class="text-lg font-semibold text-stone-900 group-hover:text-emerald-700 transition">
                {g.label}
              </div>
              <div class="text-xs text-stone-500">{g.count} {g.count === 1 ? 'charge' : 'charges'}</div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <div class="text-xs text-stone-400 uppercase tracking-wide">Total</div>
              <div class="text-2xl font-semibold text-stone-900 tabular-nums">{fmtMoney(g.total)}</div>
            </div>
            <ChevronRight size={18} class="text-stone-300 group-hover:text-emerald-600 transition" />
          </div>
        </a>
      ))}
    </div>
  )}
</AppLayout>
