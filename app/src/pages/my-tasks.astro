---
import AppLayout from '~/layouts/AppLayout.astro';
import StatusCheckbox from '~/components/StatusCheckbox.svelte';
import { ListChecks, Search, Flag } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const allowedTeams = Astro.locals.allowedTeams;
const allowedTeamIds = allowedTeams.map((t) => t.id);
const url = Astro.url;
const statusFilter = url.searchParams.get('status') ?? 'open';
const teamFilter = url.searchParams.get('team') ?? 'all';
const sort = url.searchParams.get('sort') ?? 'due';
const search = (url.searchParams.get('q') ?? '').trim();

let q = supabase
  .from('todos')
  .select(
    'id, title, status, is_urgent, due_date, created_at, team_id, assignee_employee_id, ' +
    'team:teams(id, name)',
  )
  .eq('assignee_employee_id', user.employeeId);

// Team visibility gate (belt + suspenders — todos without a team still show).
if (allowedTeamIds.length > 0) q = q.or(`team_id.in.(${allowedTeamIds.join(',')}),team_id.is.null`);

if (statusFilter === 'active') q = q.in('status', ['open', 'done']);
else if (statusFilter !== 'all') q = q.eq('status', statusFilter);
if (teamFilter !== 'all' && allowedTeamIds.includes(teamFilter)) q = q.eq('team_id', teamFilter);
if (search) q = q.ilike('title', `%${search}%`);
if (sort === 'created') q = q.order('created_at', { ascending: false });
else if (sort === 'title') q = q.order('title');
else q = q.order('due_date', { ascending: true, nullsFirst: false });

const { data: todos } = await q;
const teams = allowedTeams;

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';

// Fetch open/done counts for the subtitle regardless of active filter
const { count: openCount } = await supabase
  .from('todos')
  .select('*', { count: 'exact', head: true })
  .eq('assignee_employee_id', user.employeeId)
  .eq('status', 'open');
const { count: doneCount } = await supabase
  .from('todos')
  .select('*', { count: 'exact', head: true })
  .eq('assignee_employee_id', user.employeeId)
  .eq('status', 'done');
---
<AppLayout title="My Tasks · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-emerald-100 grid place-items-center">
        <ListChecks class="text-emerald-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">My Tasks</h1>
        <p class="text-stone-500 text-sm">
          Everything assigned to you across every team —
          <span class="text-stone-700 font-medium">{openCount ?? 0} open</span>, {doneCount ?? 0} done
        </p>
      </div>
    </div>
  </header>

  <form method="GET" class="flex flex-wrap gap-2 mb-4">
    <div class="flex-1 min-w-[240px] relative">
      <Search size={16} class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" />
      <input
        type="text"
        name="q"
        value={search}
        placeholder="Search my tasks..."
        class="w-full bg-white border border-stone-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-emerald-400"
      />
    </div>
    <select name="team" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={teamFilter === 'all'}>All teams</option>
      {teams?.map((t) => <option value={t.id} selected={teamFilter === t.id}>{t.name}</option>)}
    </select>
    <select name="status" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="active"   selected={statusFilter === 'active'}>Open &amp; Done</option>
      <option value="open"     selected={statusFilter === 'open'}>Open only</option>
      <option value="done"     selected={statusFilter === 'done'}>Done only</option>
      <option value="archived" selected={statusFilter === 'archived'}>Archived</option>
      <option value="all"      selected={statusFilter === 'all'}>All</option>
    </select>
    <select name="sort" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="due"     selected={sort === 'due'}>Due date</option>
      <option value="created" selected={sort === 'created'}>Created date</option>
      <option value="title"   selected={sort === 'title'}>Title</option>
    </select>
  </form>

  <div class="bg-white border border-stone-200 rounded-xl divide-y divide-stone-100">
    {todos && todos.length > 0 ? (
      todos.map((t: any) => {
        const done = t.status === 'done';
        return (
          <div class="flex items-center gap-3 px-4 py-3">
            <StatusCheckbox client:load id={t.id} status={t.status} endpoint="/api/todos" />
            <div class={`flex-1 text-sm ${done ? 'text-stone-400 line-through' : 'text-stone-800'}`}>
              {t.title}
            </div>
            {t.is_urgent && <Flag size={14} class="text-rose-500" />}
            {t.team && (
              <span class="text-[11px] font-medium text-stone-500 bg-stone-50 border border-stone-200 rounded-full px-2 py-0.5">
                {t.team.name}
              </span>
            )}
            {t.due_date && <span class="text-xs text-rose-500 w-14 text-right">{fmt(t.due_date)}</span>}
          </div>
        );
      })
    ) : (
      <div class="px-4 py-12 text-center text-sm text-stone-400">
        Nothing assigned to you matching the filters.
      </div>
    )}
  </div>
</AppLayout>
