---
import AppLayout from '~/layouts/AppLayout.astro';
import RichTextEditor from '~/components/RichTextEditor.svelte';
import { Megaphone, Calendar, X, Plus, Pencil, Trash2 } from 'lucide-svelte';
import { supabase } from '~/lib/supabase';

const url = Astro.url;
const category = url.searchParams.get('category') ?? 'all';
const editId = url.searchParams.get('edit');
const adding = url.searchParams.get('new') === '1';

let q = supabase
  .from('testimonials')
  .select('*')
  .eq('type', 'Update')
  .order('date', { ascending: false, nullsFirst: false });
if (category !== 'all') q = q.eq('category', category);

const { data: updates } = await q;
const { data: allCats } = await supabase.from('testimonials').select('category').eq('type', 'Update');
const categories = Array.from(new Set((allCats ?? []).map((c) => c.category).filter(Boolean))).sort() as string[];

const editing = editId ? (updates ?? []).find((u: any) => u.id === editId) ?? null : null;

const fmt = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';

const back = `/updates${category !== 'all' ? `?category=${encodeURIComponent(category)}` : ''}`;
---
<AppLayout title="Updates · GYE EOS">
  <header class="flex items-start justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-violet-100 grid place-items-center">
        <Megaphone class="text-violet-600" size={24} />
      </div>
      <div>
        <h1 class="text-2xl font-semibold text-stone-900">Updates</h1>
        <p class="text-stone-500 text-sm">News, wins, and announcements from across GYE</p>
      </div>
    </div>
    <a
      href="/updates?new=1"
      class="bg-violet-600 hover:bg-violet-700 text-white rounded-xl px-5 py-2.5 text-sm font-medium flex items-center gap-1.5"
    >
      <Plus size={16} />
      New Update
    </a>
  </header>

  <form method="GET" class="mb-6">
    <select name="category" onchange="this.form.submit()" class="bg-white border border-stone-200 rounded-xl px-4 py-2.5 text-sm">
      <option value="all" selected={category === 'all'}>All categories</option>
      {categories.map((c) => <option value={c} selected={category === c}>{c}</option>)}
    </select>
  </form>

  {updates && updates.length > 0 ? (
    <div class="columns-1 md:columns-2 lg:columns-3 gap-5 [column-fill:_balance]">
      {updates.map((u: any) => {
        const thumb = u.image_url || u.screenshot_url;
        const body = (u.notes || u.rich_text || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
        return (
          <div class="group relative mb-5 break-inside-avoid">
            <a
              href={`/updates/${u.id}`}
              class="block bg-white border border-stone-200 rounded-2xl overflow-hidden hover:border-violet-300 hover:shadow-sm transition"
            >
              {thumb && <img src={thumb} alt="" class="w-full bg-stone-100" loading="lazy" />}
              <div class="p-5">
                <div class="flex items-center gap-2 mb-2 text-xs text-stone-400">
                  {u.category && (
                    <span class="font-medium text-violet-700 bg-violet-50 border border-violet-200 rounded-full px-2 py-0.5">
                      {u.category}
                    </span>
                  )}
                  {u.date && (
                    <span class="flex items-center gap-1"><Calendar size={11} /> {fmt(u.date)}</span>
                  )}
                  {u.video_url && <span class="text-rose-500 font-medium">▶ Video</span>}
                </div>
                <h3 class="font-semibold text-stone-900 text-lg leading-snug">{u.headline || 'Untitled update'}</h3>
                {body && <p class="text-sm text-stone-500 mt-2 line-clamp-4">{body}</p>}
              </div>
            </a>
            <a
              href={`/updates?edit=${u.id}`}
              class="absolute top-3 right-3 p-2 rounded-lg bg-white/90 backdrop-blur border border-stone-200 text-stone-500 hover:text-stone-900 hover:bg-white opacity-0 group-hover:opacity-100 transition"
              title="Edit"
            >
              <Pencil size={14} />
            </a>
          </div>
        );
      })}
    </div>
  ) : (
    <div class="bg-white border border-stone-200 rounded-2xl px-4 py-12 text-center text-sm text-stone-400">
      No updates yet.
    </div>
  )}

  {/* ================== EDIT / NEW slide-over ================== */}
  {(editing || adding) && (
    <div class="fixed inset-0 z-30">
      <a href={back} class="absolute inset-0 bg-black/30"></a>
      <aside class="absolute right-0 top-0 bottom-0 w-full max-w-2xl bg-white shadow-2xl overflow-y-auto">
        <div class="p-6 space-y-5">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-semibold text-stone-900">{editing ? 'Edit Update' : 'New Update'}</h2>
            <a href={back} class="p-1 text-stone-400 hover:text-stone-700"><X size={20} /></a>
          </div>

          <form method="POST" action="/api/testimonials" class="space-y-4">
            <input type="hidden" name="_action" value={editing ? 'update' : 'create'} />
            <input type="hidden" name="type" value="Update" />
            {editing && <input type="hidden" name="id" value={editing.id} />}
            <input type="hidden" name="back" value={back} />

            <div>
              <label class="text-sm font-medium text-stone-700">Headline</label>
              <input type="text" name="headline" required value={editing?.headline ?? ''}
                class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-sm font-medium text-stone-700">Category</label>
                <input type="text" name="category" list="update-categories" value={editing?.category ?? ''}
                  placeholder="e.g. SOC, Fundraising"
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
                <datalist id="update-categories">
                  {categories.map((c) => <option value={c}></option>)}
                </datalist>
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Date</label>
                <input type="date" name="date" value={editing?.date ?? ''}
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm" />
              </div>
            </div>

            <div>
              <label class="text-sm font-medium text-stone-700">Body</label>
              <div class="mt-1">
                <RichTextEditor
                  client:only="svelte"
                  name="rich_text"
                  initial={editing?.rich_text ?? editing?.notes ?? ''}
                  autosaveUrl={editing ? '/api/testimonials' : undefined}
                  autosaveId={editing?.id}
                  autosaveField="rich_text"
                />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-sm font-medium text-stone-700">Image URL</label>
                <input type="url" name="image_url" value={editing?.image_url ?? ''}
                  placeholder="https://..."
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Screenshot URL</label>
                <input type="url" name="screenshot_url" value={editing?.screenshot_url ?? ''}
                  placeholder="https://..."
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Video URL</label>
                <input type="url" name="video_url" value={editing?.video_url ?? ''}
                  placeholder="YouTube link, .mp4, etc."
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Source link</label>
                <input type="url" name="source_link" value={editing?.source_link ?? ''}
                  placeholder="https://..."
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-sm font-medium text-stone-700">From</label>
                <input type="text" name="from_username" value={editing?.from_username ?? ''}
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
              <div>
                <label class="text-sm font-medium text-stone-700">Source</label>
                <input type="text" name="source" value={editing?.source ?? ''}
                  placeholder="Intercom, Email, Forum..."
                  class="mt-1 w-full bg-white border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-400" />
              </div>
            </div>

            <label class="flex items-center gap-2 text-sm text-stone-700">
              <input type="checkbox" name="featured_in_newsletter" checked={editing?.featured_in_newsletter} />
              Featured in newsletter
            </label>

            <button class="w-full bg-violet-600 hover:bg-violet-700 text-white rounded-lg py-2.5 text-sm font-medium">
              {editing ? 'Save update' : 'Create update'}
            </button>
          </form>

          {editing && (
            <form
              method="POST"
              action="/api/testimonials"
              class="pt-4 border-t border-stone-200"
              onsubmit="return confirm('Delete this update?');"
            >
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={editing.id} />
              <input type="hidden" name="back" value={back} />
              <button class="w-full border border-rose-300 text-rose-700 rounded-lg py-2 text-sm font-medium flex items-center justify-center gap-2">
                <Trash2 size={14} /> Delete update
              </button>
            </form>
          )}
        </div>
      </aside>
    </div>
  )}
</AppLayout>
